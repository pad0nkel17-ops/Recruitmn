{
  "version": 2,
  "framework": "vite",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/jotform-forms",
      "destination": "/api/jotform.ts"
    },
    {
      "source": "/api/jotform-submissions",
      "destination": "/api/submissions.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
